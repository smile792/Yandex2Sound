{
  "name": "yandex2sound-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c yellow,cyan \"powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-backend.ps1\" \"powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-frontend.ps1\"",
    "dev:frontend": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "effector": "^23.4.4",
    "effector-react": "^23.3.0",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
